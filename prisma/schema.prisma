generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models (NextAuth/Auth.js required) ───────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           UserRole  @default(CLINICIAN)
  specialty      String?
  licenseNumber  String?
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  encounters  Encounter[]
  notes       ClinicalNote[]
  preferences UserPreference?

  // Patient sharing relations
  patientShares   NoteShare[]       @relation("PatientShares")
  clinicianShares NoteShare[]       @relation("ClinicianShares")
  sentInvites     NoteShareInvite[] @relation("SentInvites")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Domain Models ────────────────────────────────────────────

model Encounter {
  id              String          @id @default(cuid())
  userId          String
  title           String?
  patientInitials String?
  encounterDate   DateTime        @default(now())
  encounterType   EncounterType   @default(GENERAL)
  status          EncounterStatus @default(RECORDING)
  duration        Int?

  // Audio
  audioFileUrl   String?
  audioFileKey   String?
  audioFormat    String?
  audioSizeBytes Int?

  // Relations
  transcription Transcription?
  clinicalNote  ClinicalNote?

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("encounters")
}

model Transcription {
  id           String              @id @default(cuid())
  encounterId  String              @unique
  fullText     String              @db.Text
  segments     Json
  language     String?             @default("en")
  confidence   Float?
  model        String?
  status       TranscriptionStatus @default(PENDING)
  errorMessage String?
  processingMs Int?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("transcriptions")
}

model ClinicalNote {
  id          String   @id @default(cuid())
  encounterId String   @unique
  userId      String
  title       String?
  noteType    NoteType @default(SOAP)

  // Content
  content     Json
  rawContent  String? @db.Text
  htmlContent String? @db.Text

  // Evidence links
  evidenceLinks Json?

  // AI metadata
  llmModel        String?
  llmPromptTokens Int?
  llmOutputTokens Int?

  // Status
  status   NoteStatus @default(DRAFT)
  signedAt DateTime?
  signedBy String?

  // Versioning
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter Encounter     @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  history   NoteHistory[]
  shares    NoteShare[]
  invites   NoteShareInvite[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("clinical_notes")
}

model NoteHistory {
  id         String   @id @default(cuid())
  noteId     String
  content    Json
  version    Int
  changedBy  String
  changeType String
  createdAt  DateTime @default(now())

  note ClinicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, version])
  @@map("note_history")
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  defaultNoteType NoteType @default(SOAP)
  theme           String   @default("system")
  autoSave        Boolean  @default(true)
  language        String   @default("en")
  noteFormat      String   @default("paragraph")
  visibleSections Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Note Sharing Models ──────────────────────────────────────────

model NoteShare {
  id         String    @id @default(cuid())
  noteId     String
  patientId  String
  sharedById String
  message    String?
  sharedAt   DateTime  @default(now())
  viewedAt   DateTime?

  note     ClinicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  patient  User         @relation("PatientShares", fields: [patientId], references: [id], onDelete: Cascade)
  sharedBy User         @relation("ClinicianShares", fields: [sharedById], references: [id], onDelete: Cascade)

  @@unique([noteId, patientId])
  @@index([patientId])
  @@index([noteId])
  @@map("note_shares")
}

model NoteShareInvite {
  id           String    @id @default(cuid())
  noteId       String
  patientEmail String
  invitedById  String
  token        String    @unique @default(cuid())
  message      String?
  expiresAt    DateTime
  redeemedAt   DateTime?
  createdAt    DateTime  @default(now())

  note      ClinicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  invitedBy User         @relation("SentInvites", fields: [invitedById], references: [id])

  @@index([token])
  @@index([patientEmail])
  @@map("note_share_invites")
}

// ─── Enums ─────────────────────────────────────────────────────────

enum UserRole {
  CLINICIAN
  ADMIN
  SUPER_ADMIN
  PATIENT
}

enum EncounterType {
  GENERAL
  FOLLOW_UP
  INITIAL_CONSULT
  EMERGENCY
  TELEHEALTH
  PROCEDURE
}

enum EncounterStatus {
  RECORDING
  UPLOADING
  TRANSCRIBING
  GENERATING_NOTE
  REVIEW
  COMPLETED
  ERROR
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NoteType {
  SOAP
  HP
  PROGRESS
  PROCEDURE
  DISCHARGE
  REFERRAL
}

enum NoteStatus {
  DRAFT
  REVIEW
  FINAL
  SIGNED
  AMENDED
}
